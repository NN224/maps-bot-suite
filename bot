#!/usr/bin/env python3
"""bot — Main CLI entry point for bot-suite.

Usage:
    ./bot                          # interactive (pick business + sessions)
    ./bot run <n>                  # run n sessions on the active business
    ./bot status                   # today's stats + active business
    ./bot log                      # tail live log
    ./bot stop                     # stop the running bot
    ./bot biz                      # list businesses
    ./bot biz add                  # add a new business
    ./bot biz switch <id|slug>     # set active business
    ./bot biz edit <id|slug>       # edit fields of an existing business
    ./bot biz delete <id|slug>     # remove a business (sessions kept)
    ./bot dash                     # Rich Live Dashboard (real-time, terminal)
    ./bot web                      # Local web dashboard (clickable control panel)
"""
from __future__ import annotations

import os
import signal
import subprocess
import sys
from pathlib import Path

# Make sibling packages importable
ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT))

# Re-exec under the project venv if launched with a different interpreter
# (e.g. a pyenv shim on PATH). Keeps `./bot` working without activating the venv.
# Handles both POSIX (venv/bin/python) and Windows (venv/Scripts/python.exe).
_VENV_DIR = ROOT / "venv"
_VENV_PY = _VENV_DIR / "bin" / "python"
if not _VENV_PY.exists():
    _win_py = _VENV_DIR / "Scripts" / "python.exe"
    if _win_py.exists():
        _VENV_PY = _win_py
# Re-exec into the project venv UNLESS we're already running inside it. We test
# sys.prefix (the active environment), not the executable path — a venv's python
# is a symlink to the base interpreter, so comparing resolved exe paths wrongly
# matches when the venv was created from the same python that launched us.
_in_venv = Path(sys.prefix).resolve() == _VENV_DIR.resolve()
if _VENV_PY.exists() and not _in_venv:
    os.execv(str(_VENV_PY), [str(_VENV_PY), str(Path(__file__).resolve()), *sys.argv[1:]])

import typer
from rich.console import Console
from rich.prompt import Prompt, IntPrompt, Confirm
from rich.table import Table
from rich.panel import Panel
from rich import box

app = typer.Typer(
    add_completion=False,
    no_args_is_help=False,
    help="🤖 bot-suite — Local automation suite (SBO, traffic, etc.)",
)
console = Console()

LOG_FILE = "/tmp/bot_suite.log"
PID_FILE = "/tmp/bot_suite.pid"

