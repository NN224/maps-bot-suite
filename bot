@app.callback(invoke_without_command=True)
def main(ctx: typer.Context):
    """Interactive launcher when called without arguments."""
    if ctx.invoked_subcommand is not None:
        return

    # No args = interactive flow
    pid = _is_bot_running()
    if pid:
        console.print(f"\n[yellow]⚠️  Bot already running (PID {pid})[/yellow]")
        console.print("   Run [cyan]bot stop[/cyan] to stop it, or [cyan]bot status[/cyan] to see progress.\n")
        raise typer.Exit(1)

    console.print()
    console.print(Panel.fit("🤖 [bold]bot-suite[/bold] — local automation", border_style="cyan"))
    console.print()
    console.print("🏢 [bold]Businesses[/bold]")
    console.print(_list_businesses_table())

    from shared.db import set_active_business, get_active_business
    # Validate business choice — keep asking until a valid one is selected.
    # Accepts either the # column (id) or the slug.
    while True:
        choice = Prompt.ask("\n🎯 رقم أو slug البزنس", default="1")
        try:
            if set_active_business(choice):
                break
            console.print(f"[red]❌ Not found: '{choice}'. اختر رقم (مثلاً 1) أو slug (مثلاً my-business).[/red]")
        except Exception as e:
            console.print(f"[red]❌ {e}[/red]")

    biz = get_active_business()
    console.print(f"[green]✅ {biz['name']}[/green] [dim]({biz['business_type']})[/dim]")

    sessions = IntPrompt.ask("📊 كم جلسة؟", default=10)
    use_proxy = Confirm.ask("🌐 تستخدم البروكسي (DataImpulse)؟", default=True)
    run(sessions=sessions, visible=False, foreground=False, no_proxy=not use_proxy)


if __name__ == "__main__":
    app()
