# Helpers
# ──────────────────────────────────────────────

def _is_bot_running() -> int | None:
    """Return PID if running, else None."""
    try:
        r = subprocess.run(
            ["pgrep", "-f", "scenarios.runner"],
            capture_output=True, text=True, timeout=2,
        )
        if r.returncode == 0:
            pids = [int(x) for x in r.stdout.split() if x.strip().isdigit()]
            return pids[0] if pids else None
    except Exception:
        pass
    return None


def _list_businesses_table() -> Table:
    """Build a Rich table of all businesses."""
    from shared.db import _pg_exec
    rows = _pg_exec(
        "SELECT id, slug, name, business_type, is_active "
        "FROM businesses ORDER BY id", fetchall=True,
    ) or []
    table = Table(box=box.SIMPLE_HEAVY, show_lines=False)
    table.add_column("#", style="cyan", width=4)
    table.add_column(" ", width=3)
    table.add_column("Name", style="bold")
    table.add_column("Slug", style="dim")
    table.add_column("Type")
    table.add_column("Active", width=8)
    for r in rows:
        icon = "🎯" if r["business_type"] == "sbo" else "🚗"
        active = "[green]★ ACTIVE[/green]" if r["is_active"] else ""
        type_color = "yellow" if r["business_type"] == "sbo" else "blue"
        table.add_row(
            str(r["id"]), icon, r["name"], r["slug"],
            f"[{type_color}]{r['business_type']}[/{type_color}]",
            active,
        )
    return table


def _active_business_name() -> str:
    from shared.db import get_active_business
    b = get_active_business()
    return b["name"] if b else "(none)"


def _today_stats() -> dict:
    from shared.db import _pg_exec
    rows = _pg_exec(
        "SELECT COUNT(*) AS total, "
        "SUM(CASE WHEN status='success' THEN 1 ELSE 0 END) AS success, "
        "SUM(CASE WHEN status='partial' THEN 1 ELSE 0 END) AS partial, "
        "SUM(CASE WHEN status='failed' THEN 1 ELSE 0 END) AS failed, "
        "SUM(CASE WHEN autocomplete_found THEN 1 ELSE 0 END) AS ac_found, "
        "SUM(CASE WHEN directions_clicked THEN 1 ELSE 0 END) AS directions, "
        "SUM(CASE WHEN call_clicked THEN 1 ELSE 0 END) AS calls, "
        "ROUND(AVG(CASE WHEN status<>'failed' THEN dwell_time_seconds END)::numeric, 1) AS avg_dwell "
        "FROM bot_sessions WHERE DATE(created_at AT TIME ZONE 'Asia/Dubai') = CURRENT_DATE",
        fetchall=True,
    ) or [{}]
    return rows[0]


