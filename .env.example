# ==============================================================
# bot-suite — environment template
# --------------------------------------------------------------
# Copy this file to .env and fill in real values:
#     cp .env.example .env
# NEVER commit your real .env (it is gitignored).
# Most business config (name, prefixes, place_id, geo) lives in
# the Neon `businesses` table — manage it with `./bot biz add`,
# NOT here. The keys below are the machine/infra-level settings.
# ==============================================================

# --------------------------------------------------------------
# DATABASE — single source of truth.
# Default EMPTY = local SQLite mode (tables auto-create) → works on first run,
# no setup. To use Postgres/Neon instead, put a full URL here, e.g.:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
# --------------------------------------------------------------
DATABASE_URL=

# --------------------------------------------------------------
# DASHBOARD / OWNER
# DASHBOARD_PIN is also read from Neon (sbo_config.dashboard_pin);
# this env value is a fallback.
# --------------------------------------------------------------
DASHBOARD_PIN=
DASHBOARD_SECRET=
OWNER_EMAIL=you@example.com
GMAIL_APP_PASSWORD=

# --------------------------------------------------------------
# POSITION MONITORING (optional)
# Google Places API key — used to check Maps ranking position.
# --------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
# SerpApi key (alternative position source — optional)
SERPAPI_KEY=

# --------------------------------------------------------------
# PROXY
# USE_PROXY: true / false. When false, the bot forces desktop-only.
# PROXY_PROVIDER: e.g. dataimpulse, brightdata, iproyal, webshare...
# PROXY_URL accepts any of these formats (auto-detected):
#   host:port:user:pass        (DataImpulse style)
#   user:pass@host:port
#   http://user:pass@host:port
#   socks5://user:pass@host:port
# --------------------------------------------------------------
USE_PROXY=false
PROXY_PROVIDER=
PROXY_URL=http://USER:PASS@host:port

# Bright Data (only if PROXY_PROVIDER=brightdata) — optional
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE=
BRIGHTDATA_PASSWORD=

# SOAX (only if using SOAX) — optional
SOAX_API_KEY=
SOAX_HOST=
SOAX_PORT=

# --------------------------------------------------------------
# BROWSER
# BROWSER_CHANNEL: empty = bundled Chromium; "chrome" = local Chrome.
# BLOCK_MEDIA: true to block images/media for speed (optional).
# --------------------------------------------------------------
BROWSER_CHANNEL=
BLOCK_MEDIA=false

# --------------------------------------------------------------
# DEVICE DISTRIBUTION (0..1). 0/0 = desktop only (recommended
# unless you have a residential mobile proxy in the target country).
# --------------------------------------------------------------
MOBILE_PCT=0
TABLET_PCT=0

# --------------------------------------------------------------
# LEGACY (Supabase REST fallback) — leave empty unless migrating.
# --------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
